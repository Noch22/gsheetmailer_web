---
import Layout from '../layouts/Layout.astro';
import productIcon from '../assets/icon128.png';
import step1Image from '../assets/step_1.png';
import step2Image from '../assets/step_2.png';
import step3Image from '../assets/step_3.png';
import { SITE } from '../consts';
import { buildUrl, getTranslation, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
const base = import.meta.env.BASE_URL;
const homeUrl = buildUrl(base, lang, '/');
const privacyUrl = buildUrl(base, lang, '/privacy/');
const feedbackUrl = 'https://feedback.gsheetmailer.com';
const blogUrl = buildUrl(base, lang, '/blog/');
const frHomeUrl = buildUrl(base, 'fr', '/');
const enHomeUrl = buildUrl(base, 'en', '/');
const pagePath = lang === 'fr' ? '/' : '/en/';
const stepImages = [step1Image, step2Image, step3Image];

// Replace this link with your own YouTube video URL.
const youtubeVideoUrl = 'https://youtu.be/EYNpylyoDu8';
const youtubeVideoId = youtubeVideoUrl.match(/(?:v=|be\/|embed\/)([A-Za-z0-9_-]{11})/)?.[1] ?? '';
const youtubeEmbedUrl = youtubeVideoId
  ? `https://www.youtube-nocookie.com/embed/${youtubeVideoId}?rel=0&modestbranding=1`
  : '';

---

<Layout title={t.meta.homeTitle} description={t.meta.homeDescription} path={pagePath} lang={lang}>
  <header class="site-header site-header-sticky">
    <div class="container header-inner">
      <a class="site-brand" href={homeUrl}>
        <img src={productIcon.src} alt="" width="40" height="40" />
        <span>{SITE.productName}</span>
      </a>

      <nav class="section-nav" aria-label={t.nav.sectionsLabel}>
        <a href="#how">{t.how.title}</a>
        <a href="#benefits">{t.benefits.kicker}</a>
        <a href="#reviews">{t.homeUi.reviewsNav}</a>
        <a href="#trust">{t.trust.kicker}</a>
        <a href="#faq">{t.faq.kicker}</a>
      </nav>

      <div class="header-actions">
        <nav class="lang-switch" aria-label={t.nav.langSwitcherLabel}>
          <a class:list={["lang-pill", { active: lang === 'fr' }]} href={frHomeUrl}>FR</a>
          <a class:list={["lang-pill", { active: lang === 'en' }]} href={enHomeUrl}>EN</a>
        </nav>
        <a class="button primary" href={SITE.betaAccessUrl} target="_blank" rel="noreferrer" data-umami-event="beta_click_header" data-umami-event-lang={lang}>
          {t.hero.betaCta}
        </a>
        <!-- <a class="button primary" href={SITE.extensionUrl} target="_blank" rel="noreferrer" data-umami-event="install_click_header" data-umami-event-lang={lang}>
          {t.hero.primaryCta}
        </a> -->
      </div>
    </div>
  </header>

  <main>
    <section class="hero hero-split">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="container hero-grid">
        <div class="hero-copy reveal-up">
          <p class="eyebrow">{t.hero.eyebrow}</p>
          <h1>{t.hero.title}</h1>
          <p class="hero-lead">{t.hero.text}</p>
          <div class="actions">
            <a class="button primary large" href={SITE.betaAccessUrl} target="_blank" rel="noreferrer" data-umami-event="beta_click_hero" data-umami-event-lang={lang}>{t.hero.betaCta}</a>
            <a class="button secondary large" href={privacyUrl} data-umami-event="privacy_click_hero" data-umami-event-lang={lang}>{t.hero.secondaryCta}</a>
          </div>
          <p class="hero-proof">{t.hero.proof}</p>
          <div class="hero-chips" aria-label={t.homeUi.highlightsAriaLabel}>
            {t.homeUi.heroChips.map((chip) => (
              <span>{chip}</span>
            ))}
          </div>
        </div>

        <div class="hero-visual reveal-up-delay">
          <article class="hero-product-card float-soft">
            <img
              src={stepImages[0].src}
              alt={`${t.how.stepLabel} 1`}
              width={stepImages[0].width}
              height={stepImages[0].height}
              loading="eager"
            />
            <div class="hero-product-copy">
              <strong>{t.homeUi.heroPreviewTitle}</strong>
              <p>{t.homeUi.heroPreviewText}</p>
            </div>
          </article>

          <div class="floating-note top">{t.homeUi.floatingNotes[0]}</div>
          <div class="floating-note bottom">{t.homeUi.floatingNotes[1]}</div>
        </div>
      </div>
    </section>

    <section class="section section-tight partner-strip">
      <div class="container">
        <p class="strip-label">{t.homeUi.partnerStripLabel}</p>
        <div class="logo-row" aria-label={t.homeUi.logoRowAriaLabel}>
          {t.homeUi.logoRow.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="section video-showcase section-tight-top">
      <div class="container">
        <div class="video-card">
          <div class="video-copy">
            <p class="section-kicker">{t.video.kicker}</p>
            <h2>{t.video.title}</h2>
            <p>{t.video.text}</p>
          </div>
          <div class="video-shell">
            {youtubeEmbedUrl ? (
              <iframe
                src={youtubeEmbedUrl}
                title={t.video.iframeTitle}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                referrerpolicy="strict-origin-when-cross-origin"
              ></iframe>
            ) : (
              <div class="video-fallback">
                <p>{t.video.fallback}</p>
              </div>
            )}
          </div>

        </div>
      </div>
    </section>

    <section id="how" class="container product-preview">
      <div class="preview-copy reveal-up">
        <h2>{t.preview.title}</h2>
        <p>{t.preview.text}</p>
      </div>
      <div class="step-gallery">
        {t.how.steps.map((step, index) => (
          <article class="step-shot reveal-up-stagger">
            <img
              src={stepImages[index].src}
              alt={`${t.how.stepLabel} ${index + 1}: ${step.title}`}
              width={stepImages[index].width}
              height={stepImages[index].height}
              loading="lazy"
            />
            <div class="step-shot-copy">
              <strong>{t.how.stepLabel} {index + 1}</strong>
              <p>{step.title}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="benefits" class="section">
      <div class="container">
        <p class="section-kicker">{t.benefits.kicker}</p>
        <h2>{t.benefits.title}</h2>
        <div class="benefit-grid benefit-grid-compact">
          {t.workflow.cards.map((card) => (
            <article class="benefit-card reveal-up-stagger">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </article>
          ))}
          {t.why.items.map((item) => (
            <article class="benefit-card reveal-up-stagger">
              <h3>{item}</h3>
              <p>{t.benefits.itemText}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="reviews" class="section section-soft">
      <div class="container">
        <p class="section-kicker">{t.homeUi.reviewsKicker}</p>
        <h2>{t.homeUi.reviewsTitle}</h2>
        <div class="testimonial-grid">
          {t.homeUi.testimonials.map((item) => (
            <article class="testimonial-card reveal-up-stagger">
              <p class="stars" aria-hidden="true">★★★★★</p>
              <p>{item.quote}</p>
              <strong>{item.author}</strong>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="trust" class="section section-dark">
      <div class="container trust-grid">
        <div>
          <p class="section-kicker">{t.trust.kicker}</p>
          <h2>{t.trust.title}</h2>
          <p>{t.trust.text}</p>
          <a class="button secondary inverse" href={privacyUrl} data-umami-event="privacy_click_trust" data-umami-event-lang={lang}>{t.hero.secondaryCta}</a>
        </div>
        <div class="trust-items">
          {t.trust.items.map((item) => (
            <article class="trust-item">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>


    <section id="faq" class="section">
      <div class="container faq-wrap">
        <p class="section-kicker">{t.faq.kicker}</p>
        <h2>{t.faq.title}</h2>
        <div class="faq-list">
          {t.faq.items.map((item) => (
            <details class="faq-item">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section id="beta-form" class="section">
      <div class="container final-cta">
        <h2>{t.finalCta.title}</h2>
        <p>{t.finalCta.text}</p>
        <div class="actions center">
          <!-- <a class="button primary large" href={SITE.extensionUrl} target="_blank" rel="noreferrer" data-umami-event="install_click_final" data-umami-event-lang={lang}>{t.hero.primaryCta}</a> -->
          <a class="button primary large" href={SITE.betaAccessUrl} target="_blank" rel="noreferrer" data-umami-event="beta_click_final" data-umami-event-lang={lang}>{t.hero.betaCta}</a>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container blog-teaser">
        <h2>{t.blog.title}</h2>
        <p>{t.blog.text}</p>
        <div class="actions center">
          <a class="button secondary" href={blogUrl} data-umami-event="blog_click_home" data-umami-event-lang={lang}>{t.blog.cta}</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p>© 2026 {SITE.productName}</p>
      <p>
        <a href={feedbackUrl} target="_blank" data-umami-event="feedback_click_footer" data-umami-event-lang={lang}>{t.footer.feedback}</a>
        {' • '}
        <a href={privacyUrl} data-umami-event="privacy_click_footer" data-umami-event-lang={lang}>{t.footer.privacy}</a>
        {' • '}
        <a href={blogUrl} data-umami-event="blog_click_footer" data-umami-event-lang={lang}>{t.footer.blog}</a>
      </p>
    </div>
  </footer>
</Layout>
