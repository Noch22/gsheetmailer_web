---
import Layout from '../layouts/Layout.astro';
import productIcon from '../assets/icon128.png';
import step1Image from '../assets/step_1.png';
import step2Image from '../assets/step_2.png';
import step3Image from '../assets/step_3.png';
import { SITE } from '../consts';
import { buildUrl, getTranslation, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
const base = import.meta.env.BASE_URL;
const homeUrl = buildUrl(base, lang, '/');
const privacyUrl = buildUrl(base, lang, '/privacy/');
const blogUrl = buildUrl(base, lang, '/blog/');
const frHomeUrl = buildUrl(base, 'fr', '/');
const enHomeUrl = buildUrl(base, 'en', '/');
const pagePath = lang === 'fr' ? '/' : '/en/';
const stepImages = [step1Image, step2Image, step3Image];
---

<Layout title={t.meta.homeTitle} description={t.meta.homeDescription} path={pagePath} lang={lang}>
  <main class="page">
    <header class="site-header">
      <a class="site-brand" href={homeUrl}>
        <img src={productIcon.src} alt="" width="40" height="40" />
        <span>{SITE.productName}</span>
      </a>

      <nav class="lang-switch" aria-label={t.nav.langSwitcherLabel}>
        <a class:list={["lang-pill", { active: lang === 'fr' }]} href={frHomeUrl}>FR</a>
        <a class:list={["lang-pill", { active: lang === 'en' }]} href={enHomeUrl}>EN</a>
      </nav>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">{t.hero.eyebrow}</p>
        <h1>{t.hero.title}</h1>
        <p>{t.hero.text}</p>

        <div class="actions">
          
          <a class="button primary" href={SITE.betaAccessUrl} target="_blank" rel="noreferrer">
            {t.hero.betaCta}
          </a>
          <a class="button secondary" href={privacyUrl}>{t.hero.secondaryCta}</a>
        </div>
      </div>

      <aside class="hero-card" aria-label="Product overview">
        <h2>{t.why.title}</h2>
        <ul class="feature-list">
          {t.why.items.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </section>


    <section class="panel">
      <h2>{t.preview.title}</h2>
      <p class="meta">{t.preview.text}</p>
      <div class="step-gallery">
        {t.how.steps.map((step, index) => (
          <article class="step-shot">
            <img
              src={stepImages[index].src}
              alt={`${t.how.stepLabel} ${index + 1}: ${step.title}`}
              width={stepImages[index].width}
              height={stepImages[index].height}
              loading="lazy"
            />
            <div class="step-shot-copy">
              <strong>{t.how.stepLabel} {index + 1}</strong>
              <p>{step.title}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="panel">
      <h2>{t.workflow.title}</h2>
      <div class="grid">
        {t.workflow.cards.map((card) => (
          <div class="stat">
            <strong>{card.title}</strong>
            <p>{card.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="panel blog-teaser">
      <h2>{t.blog.title}</h2>
      <p>{t.blog.text}</p>
      <div class="actions">
        <a class="button secondary" href={blogUrl}>{t.blog.cta}</a>
      </div>
    </section>
  </main>

  <footer>
    © 2026 {SITE.productName} • <a href={privacyUrl}>{t.footer.privacy}</a> • <a href={blogUrl}>{t.footer.blog}</a>
  </footer>
</Layout>
