---
interface Props {
	title?: string;
	description?: string;
	path?: string;
	lang?: string;
	keywords?: string[];
	ogType?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	noindex?: boolean;
}

const {
	title = 'GSheetMailer | Send personalized emails from Google Sheets',
	description = 'Send personalized emails from Google Sheets with Gmail without scripts or technical complexity.',
	path = '/',
	lang = 'en',
	keywords = [],
	ogType = 'website',
	publishedTime,
	modifiedTime,
	noindex = false,
} = Astro.props;

const baseUrl = Astro.site ?? new URL('https://gsheetmailer.com');
const canonical = new URL(path, baseUrl).toString();
const assetBase = import.meta.env.BASE_URL;
const enPath = lang === 'en' ? path : path === '/' ? '/en/' : `/en${path}`;
const frPath = lang === 'en' ? path.replace(/^\/en(?=\/|$)/, '') || '/' : path;
const enCanonical = new URL(enPath, baseUrl).toString();
const frCanonical = new URL(frPath, baseUrl).toString();
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const alternateLocale = lang === 'fr' ? 'en_US' : 'fr_FR';
const twitterTitle = title;
const twitterDescription = description;

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'GSheetMailer',
	url: new URL('/', baseUrl).toString(),
	inLanguage: ['fr', 'en'],
};

const organizationJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'GSheetMailer',
	url: new URL('/', baseUrl).toString(),
	email: 'support@gsheetmailer.com',
	logo: new URL(`${assetBase}favicon.svg`, baseUrl).toString(),
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
		<link rel="icon" href={`${assetBase}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang="fr" href={frCanonical} />
		<link rel="alternate" hreflang="en" href={enCanonical} />
		<link rel="alternate" hreflang="x-default" href={frCanonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="GSheetMailer" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={alternateLocale} />
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={twitterTitle} />
		<meta name="twitter:description" content={twitterDescription} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
		<script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)}></script>
		<script defer src="https://umami.noahbuisson.fr/script.js" data-website-id="8d94c045-1211-49eb-b526-37b926c92db8"></script>
		<script defer src="https://umami.noahbuisson.fr/recorder.js" data-website-id="8d94c045-1211-49eb-b526-37b926c92db8" data-sample-rate="1" data-mask-level="moderate" data-max-duration="300000"></script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #fbf8f2;
		--surface: #ffffff;
		--surface-soft: #f4efe5;
		--text: #172033;
		--muted: #55627a;
		--line: #e4ded2;
		--primary: #135d66;
		--primary-strong: #0e4e56;
		--accent: #ffb347;
		--dark: #1f2937;
		--shadow: 0 18px 45px rgba(23, 32, 51, 0.09);
		--radius: 18px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		font-family: 'DM Sans', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		background:
			radial-gradient(circle at top, rgba(255, 179, 71, 0.2), transparent 0 34%),
			var(--bg);
		color: var(--text);
		min-height: 100vh;
	}

	h1,
	h2,
	h3 {
		font-family: 'Space Grotesk', 'DM Sans', sans-serif;
		letter-spacing: -0.02em;
	}

	a {
		color: inherit;
	}

	.container {
		max-width: 1160px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.site-header {
		position: relative;
		z-index: 20;
	}

	.site-header-sticky {
		position: sticky;
		top: 0;
		backdrop-filter: blur(12px);
		background: rgba(251, 248, 242, 0.82);
		border-bottom: 1px solid var(--line);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		min-height: 74px;
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
		font-weight: 800;
		font-size: 1.05rem;
	}

	.site-brand img {
		width: 40px;
		height: 40px;
		border-radius: 12px;
		box-shadow: 0 10px 26px rgba(19, 93, 102, 0.28);
	}

	.section-nav {
		display: flex;
		gap: 22px;
		align-items: center;
	}

	.section-nav a {
		text-decoration: none;
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--muted);
	}

	.section-nav a:hover {
		color: var(--text);
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.lang-switch {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.lang-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 7px 11px;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: var(--surface);
		text-decoration: none;
		font-size: 0.84rem;
		font-weight: 700;
	}

	.lang-pill.active {
		background: rgba(19, 93, 102, 0.14);
		color: var(--primary);
		border-color: rgba(19, 93, 102, 0.35);
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 7px 12px;
		border-radius: 999px;
		background: rgba(19, 93, 102, 0.12);
		color: var(--primary);
		font-size: 0.88rem;
		font-weight: 700;
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 80px 0 44px;
	}

	.hero.hero-split {
		padding: 72px 0 34px;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(55% 46% at 50% 0%, rgba(255, 179, 71, 0.42), transparent 70%),
			repeating-linear-gradient(0deg, rgba(23, 32, 51, 0.04) 0 1px, transparent 1px 56px),
			repeating-linear-gradient(90deg, rgba(23, 32, 51, 0.04) 0 1px, transparent 1px 56px);
		mask-image: linear-gradient(to bottom, black 0%, black 82%, transparent 100%);
		pointer-events: none;
	}

	.hero-inner {
		position: relative;
		text-align: center;
	}

	.hero-grid {
		position: relative;
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: 26px;
		align-items: center;
	}

	.hero-copy {
		text-align: left;
	}

	.hero-visual {
		position: relative;
		min-height: 360px;
	}

	.hero-product-card {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 22px;
		overflow: hidden;
		box-shadow: var(--shadow);
	}

	.hero-product-card img {
		display: block;
		width: 100%;
		height: 250px;
		object-fit: contain;
		background: #f6f2e9;
	}

	.hero-product-copy {
		padding: 16px;
	}

	.hero-product-copy strong {
		display: block;
		margin-bottom: 4px;
	}

	.hero-product-copy p {
		margin: 0;
	}

	.hero-chips {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-top: 10px;
	}

	.hero-chips span {
		padding: 7px 10px;
		border-radius: 999px;
		background: var(--surface);
		border: 1px solid var(--line);
		font-size: 0.82rem;
		font-weight: 700;
		color: #344257;
	}

	.floating-note {
		position: absolute;
		padding: 9px 12px;
		border-radius: 999px;
		background: #fff;
		border: 1px solid var(--line);
		font-size: 0.8rem;
		font-weight: 700;
		box-shadow: 0 10px 30px rgba(23, 32, 51, 0.12);
	}

	.floating-note.top {
		top: -10px;
		right: 22px;
	}

	.floating-note.bottom {
		bottom: 14px;
		left: -10px;
	}

	h1 {
		font-size: clamp(2.25rem, 5.8vw, 5rem);
		line-height: 1.02;
		margin: 16px auto;
		max-width: 900px;
	}

	.hero-lead {
		font-size: clamp(1.05rem, 2vw, 1.26rem);
		line-height: 1.7;
		color: var(--muted);
		max-width: 62ch;
		margin: 0;
	}

	.hero-proof {
		font-size: 0.86rem;
		font-weight: 600;
		color: var(--muted);
		margin-top: 12px;
	}

	.section-tight {
		padding-top: 22px;
		padding-bottom: 14px;
	}

	.section-tight-top {
		padding-top: 20px;
	}

	.partner-strip .container {
		border-top: 1px solid var(--line);
		padding-top: 14px;
	}

	.strip-label {
		font-size: 0.84rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin: 0 0 10px;
		color: #6d7686;
	}

	.logo-row {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 10px;
	}

	.logo-row span {
		display: inline-flex;
		justify-content: center;
		align-items: center;
		text-align: center;
		min-height: 42px;
		border-radius: 12px;
		border: 1px solid var(--line);
		background: var(--surface);
		font-size: 0.86rem;
		font-weight: 700;
		color: #425066;
	}

	p,
	li {
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.brand-mark {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 10px;
		flex-wrap: wrap;
	}

	.brand-mark img {
		width: 64px;
		height: 64px;
		border-radius: 16px;
		box-shadow: 0 10px 30px rgba(37, 99, 235, 0.16);
	}

	.actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		margin-top: 24px;
	}

	.actions.center {
		justify-content: center;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 11px 17px;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		border: 1px solid transparent;
		transition:
			transform 0.15s ease,
			background 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button.large {
		padding: 13px 24px;
		font-size: 0.98rem;
	}

	.button.primary {
		background: var(--primary);
		color: #fff;
	}

	.button.primary:hover {
		background: var(--primary-strong);
	}

	.button.secondary {
		background: var(--surface);
		border-color: var(--line);
		color: var(--text);
	}

	.button.ghost {
		background: transparent;
		border-color: var(--line);
		color: var(--text);
	}

	.button.inverse {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.28);
		color: #fff;
	}

	.section {
		padding: 74px 0;
	}

	.section-soft {
		background: var(--surface-soft);
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.section-dark {
		background: var(--dark);
		color: #fff;
	}

	.section-dark p,
	.section-dark li {
		color: rgba(255, 255, 255, 0.8);
	}

	.section-kicker {
		font-size: 0.78rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		font-weight: 800;
		color: var(--primary);
		margin: 0 0 8px;
	}

	h2 {
		font-size: clamp(1.7rem, 3.8vw, 3rem);
		line-height: 1.08;
		margin: 0 0 14px;
	}

	.product-preview {
		padding: 22px 24px 78px;
	}

	.video-showcase {
		padding-bottom: 16px;
	}

	.video-card {
		background: linear-gradient(145deg, #fffdf8 0%, #f7f1e5 100%);
		border: 1px solid var(--line);
		border-radius: 26px;
		padding: 28px;
		box-shadow: var(--shadow);
	}

	.video-copy {
		text-align: center;
		max-width: 740px;
		margin: 0 auto 18px;
	}

	.video-copy p {
		margin: 0;
	}

	.video-shell {
		position: relative;
		width: min(100%, 940px);
		margin: 0 auto;
		aspect-ratio: 16 / 9;
		border-radius: 18px;
		overflow: hidden;
		background: #0f1727;
		border: 1px solid rgba(23, 32, 51, 0.26);
		box-shadow: 0 24px 55px rgba(15, 23, 39, 0.28);
	}

	.video-shell iframe,
	.video-fallback {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.video-shell iframe {
		border: 0;
		display: block;
	}

	.video-fallback {
		display: grid;
		place-items: center;
		padding: 20px;
		text-align: center;
	}

	.video-fallback p {
		color: rgba(255, 255, 255, 0.88);
		font-weight: 600;
		max-width: 56ch;
	}

	.preview-copy {
		text-align: center;
		max-width: 760px;
		margin: 0 auto 20px;
	}

	.step-gallery {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 18px;
		margin-top: 18px;
	}

	.step-shot {
		margin: 0;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--shadow);
	}

	.step-shot img {
		display: block;
		width: 100%;
		height: 210px;
		object-fit: contain;
		background: #f8f5ee;
	}

	.step-shot-copy {
		padding: 16px;
	}

	.step-shot-copy strong {
		display: block;
		margin-bottom: 4px;
	}

	.step-shot-copy p {
		margin: 0;
	}

	.how-grid,
	.benefit-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		margin-top: 20px;
	}

	.benefit-grid.benefit-grid-compact {
		gap: 14px;
	}

	.how-card,
	.benefit-card {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		padding: 22px;
		box-shadow: var(--shadow);
	}

	.how-index {
		display: inline-flex;
		margin-bottom: 12px;
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--primary);
	}

	.how-card h3,
	.benefit-card h3,
	.trust-item h3 {
		margin: 0 0 8px;
		font-size: 1.14rem;
	}

	.how-card p,
	.benefit-card p,
	.trust-item p {
		margin: 0;
	}

	.trust-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 24px;
		align-items: start;
	}

	.trust-items {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
	}

	.trust-item {
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: var(--radius);
		padding: 18px;
		background: rgba(255, 255, 255, 0.03);
	}

	.testimonial-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin-top: 20px;
	}

	.testimonial-card {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		padding: 20px;
		box-shadow: var(--shadow);
	}

	.testimonial-card p {
		margin: 0;
	}

	.testimonial-card .stars {
		margin-bottom: 10px;
		color: #c8841d;
		font-weight: 700;
		font-size: 0.92rem;
		letter-spacing: 0.1em;
	}

	.testimonial-card strong {
		display: inline-block;
		margin-top: 10px;
		font-size: 0.9rem;
	}

	.custom-content-shell {
		background: var(--surface);
		border: 1px dashed #d5ccb9;
		border-radius: 24px;
		padding: 26px;
	}

	.custom-content-shell h2,
	.custom-content-shell p {
		max-width: 72ch;
	}

	.custom-content-shell p {
		margin-top: 0;
	}

	.content-placeholder-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 12px;
		margin-top: 18px;
	}

	.content-placeholder {
		border: 1px dashed #cdbfa4;
		border-radius: 14px;
		padding: 18px;
		background: #fcfaf5;
		min-height: 140px;
	}

	.content-placeholder h3 {
		margin: 0 0 8px;
		font-size: 1rem;
	}

	.content-placeholder p {
		margin: 0;
	}

	.reveal-up,
	.reveal-up-delay,
	.reveal-up-stagger {
		opacity: 0;
		transform: translateY(12px);
		animation: revealUp 0.7s ease forwards;
	}

	.reveal-up-delay {
		animation-delay: 0.14s;
	}

	.reveal-up-stagger:nth-child(2) {
		animation-delay: 0.08s;
	}

	.reveal-up-stagger:nth-child(3) {
		animation-delay: 0.16s;
	}

	.reveal-up-stagger:nth-child(4) {
		animation-delay: 0.24s;
	}

	.reveal-up-stagger:nth-child(5) {
		animation-delay: 0.32s;
	}

	.reveal-up-stagger:nth-child(6) {
		animation-delay: 0.4s;
	}

	.float-soft {
		animation: floatSoft 4.6s ease-in-out infinite;
	}

	@keyframes revealUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes floatSoft {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-6px);
		}
	}

	.faq-wrap {
		max-width: 860px;
	}

	.faq-list {
		display: grid;
		gap: 12px;
		margin-top: 20px;
	}

	.faq-item {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 14px;
		padding: 14px 16px;
		box-shadow: var(--shadow);
	}

	.faq-item summary {
		cursor: pointer;
		font-weight: 700;
		color: var(--text);
	}

	.faq-item p {
		margin: 8px 0 0;
	}

	.final-cta {
		background: var(--dark);
		border-radius: 28px;
		padding: 52px 24px;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.final-cta h2,
	.final-cta p {
		position: relative;
		z-index: 1;
		color: #fff;
	}

	.final-cta p {
		max-width: 720px;
		margin: 0 auto;
		opacity: 0.82;
	}

	.blog-teaser {
		text-align: center;
	}

	.blog-teaser p {
		max-width: 72ch;
		margin: 0 auto;
	}

	.blog-page {
		padding-top: 34px;
		padding-bottom: 56px;
	}

	.blog-hero,
	.blog-post-hero {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		box-shadow: var(--shadow);
		padding: 28px;
		margin-bottom: 22px;
	}

	.blog-hero p,
	.blog-post-hero p {
		max-width: 74ch;
	}

	.blog-list-wrap h2 {
		margin-bottom: 12px;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.blog-card {
		background: var(--surface);
