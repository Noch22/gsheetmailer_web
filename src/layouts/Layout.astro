---
interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const {
	title = 'GSheetMailer | Send personalized emails from Google Sheets',
	description = 'Send personalized emails from Google Sheets with Gmail without scripts or technical complexity.',
	path = '/',
} = Astro.props;

const baseUrl = Astro.site ?? new URL('https://gsheetmailer.com');
const canonical = new URL(path, baseUrl).toString();
const assetBase = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
		<link rel="icon" href={`${assetBase}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary_large_image" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f7f9fc;
		--surface: #ffffff;
		--surface-soft: #f1f5f9;
		--text: #102033;
		--muted: #5b6b82;
		--line: #dbe4f0;
		--primary: #2563eb;
		--primary-dark: #1d4ed8;
		--shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		font-family: Inter, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		background:
			radial-gradient(circle at top, rgba(37, 99, 235, 0.08), transparent 0 30%),
			var(--bg);
		color: var(--text);
		min-height: 100vh;
	}

	a {
		color: inherit;
	}

	.page {
		max-width: 1120px;
		margin: 0 auto;
		padding: 24px;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 10px;
		border-radius: 999px;
		background: rgba(37, 99, 235, 0.1);
		color: var(--primary-dark);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.hero,
	.policy-hero {
		padding: 40px 0 24px;
	}

	.brand-mark {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 10px;
		flex-wrap: wrap;
	}

	.brand-mark img {
		width: 64px;
		height: 64px;
		border-radius: 16px;
		box-shadow: 0 10px 30px rgba(37, 99, 235, 0.16);
	}

	.hero {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 24px;
		align-items: center;
	}

	.hero-card,
	.panel,
	.policy-card {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 20px;
		box-shadow: var(--shadow);
	}

	.hero-copy,
	.hero-card,
	.panel,
	.policy-card {
		padding: 24px;
	}

	h1 {
		font-size: clamp(2.3rem, 5vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
		margin: 14px 0;
	}

	h2 {
		font-size: 1.5rem;
		margin: 0 0 14px;
	}

	p,
	li {
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		margin-top: 24px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 18px;
		border-radius: 12px;
		text-decoration: none;
		font-weight: 700;
		transition:
			transform 0.15s ease,
			background 0.15s ease,
			border-color 0.15s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button.primary {
		background: var(--primary);
		color: white;
	}

	.button.primary:hover {
		background: var(--primary-dark);
	}

	.button.secondary {
		background: var(--surface);
		border: 1px solid var(--line);
		color: var(--text);
	}

	.feature-list,
	.steps,
	.quick-points {
		margin: 0;
		padding-left: 20px;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
		margin-top: 16px;
	}

	.panel {
		margin-top: 20px;
	}

	.step {
		padding: 18px;
		border-radius: 16px;
		background: var(--surface-soft);
		border: 1px solid var(--line);
	}

	.step strong,
		.stat strong {
		display: block;
		color: var(--text);
		margin-bottom: 6px;
	}

	.stat {
		padding: 16px;
		border-radius: 16px;
		background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
		border: 1px solid var(--line);
	}

	.policy-card h2 {
		margin-top: 24px;
	}

	.policy-card h2:first-child {
		margin-top: 0;
	}

	.meta {
		font-size: 0.95rem;
	}

	footer {
		padding: 20px 24px 40px;
		text-align: center;
		color: var(--muted);
	}

	@media (max-width: 820px) {
		.hero,
		.grid {
			grid-template-columns: 1fr;
		}

		.page {
			padding: 16px;
		}

		.hero-copy,
		.hero-card,
		.panel,
		.policy-card {
			padding: 20px;
		}
	}
</style>
