---
import { SITE } from '../../consts';
import { getTranslation, buildUrl, type Lang } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import productIcon from '../../assets/icon128.png';
import { isPublished } from '../../utils/publishing';


type Props = {
  post: CollectionEntry<'blog'>;
  lang: Lang;
};

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => data.lang === 'fr' && !data.draft)).filter((post) =>
    isPublished(post),
  );

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, lang: 'fr' },
  }));
}

const { post, lang } = Astro.props as Props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const t = getTranslation(lang);
const privacyUrl = buildUrl(base, lang, '/privacy/');
const homeUrl = buildUrl(base, lang, '/');
const frBlogUrl = buildUrl(base, 'fr', '/blog/');
const enBlogUrl = buildUrl(base, 'en', '/blog/');
const baseUrl = Astro.site ?? new URL('https://gsheetmailer.com');
const articleUrl = new URL(`/blog/${post.id}/`, baseUrl).toString();
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  inLanguage: 'fr',
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  mainEntityOfPage: articleUrl,
  author: {
    '@type': 'Organization',
    name: SITE.productName,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.productName,
  },
  keywords: post.data.keywords,
};
---

<Layout
  title={`${post.data.title} | Blog GSheetMailer`}
  description={post.data.description}
  path={`/blog/${post.id}/`}
  lang="fr"
  keywords={post.data.keywords}
  ogType="article"
  publishedTime={post.data.publishDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.publishDate).toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)}></script>
  <header class="site-header site-header-sticky">
    <div class="container header-inner">
      <a class="site-brand" href={homeUrl}>
        <img src={productIcon.src} alt="" width="40" height="40" />
        <span>{SITE.productName}</span>
      </a>
      <nav class="lang-switch" aria-label={t.nav.langSwitcherLabel}>
        <a class:list={["lang-pill", { active: lang === 'fr' }]} href={frBlogUrl} data-umami-event="language_switch_blog_article" data-umami-event-lang="fr" data-umami-event-post={post.id}>FR</a>
        <a class:list={["lang-pill", { active: lang === 'en' }]} href={enBlogUrl} data-umami-event="language_switch_blog_article" data-umami-event-lang="en" data-umami-event-post={post.id}>EN</a>
      </nav>
    </div>
  </header>

  <main class="blog-page container">
    <section class="blog-post-hero">
      <p class="eyebrow">Blog</p>
      <h1>{post.data.title}</h1>
      <p class="meta">Publie le {post.data.publishDate.toLocaleDateString('fr-FR')}</p>
      <a class="button secondary" href={`${base}blog/`} data-umami-event="blog_back_to_index" data-umami-event-lang="fr" data-umami-event-post={post.id}>Retour au blog</a>
    </section>

    <article class="article-content">
      <Content />
    </article>

    <section class="post-cta">
      <h2>{t.hero.title}</h2>
      <p>{t.hero.text}</p>
      <div class="actions center">
        <!-- <a class="button primary" href={SITE.extensionUrl} target="_blank" rel="noreferrer" data-umami-event="install_click_article" data-umami-event-lang="fr" data-umami-event-post={post.id}>{t.hero.primaryCta}</a> -->
        <a class="button primary" href={SITE.betaAccessUrl} target="_blank" rel="noreferrer" data-umami-event="beta_click_article" data-umami-event-lang="fr" data-umami-event-post={post.id}>{t.hero.betaCta}</a>
        <a class="button ghost" href={privacyUrl} data-umami-event="privacy_click_article" data-umami-event-lang="fr" data-umami-event-post={post.id}>{t.hero.secondaryCta}</a>
      </div>
    </section>
  </main>
</Layout>
